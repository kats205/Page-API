# Copy this file to .env for local-only secrets. Do not commit .env.

# Facebook / Meta
FACEBOOK_PAGE_ID=YOUR_PAGE_ID
FACEBOOK_PAGE_ACCESS_TOKEN=YOUR_PAGE_ACCESS_TOKEN
FACEBOOK_APP_SECRET=YOUR_FACEBOOK_APP_SECRET
FACEBOOK_WEBHOOK_VERIFY_TOKEN=YOUR_WEBHOOK_VERIFY_TOKEN

# Backend admin API
ADMIN_API_KEY=YOUR_ADMIN_API_KEY

# Gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# Database
POSTGRES_CONNECTION_STRING=Host=localhost;Port=5432;Database=pageapi;Username=postgres;Password=postgres

# Alertmanager
DISCORD_WEBHOOK_URL=YOUR_DISCORD_WEBHOOK_URL
