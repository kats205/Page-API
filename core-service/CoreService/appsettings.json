{
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "RawEventsTopic": "raw_events",
    "ReplyCommandsTopic": "reply_commands",
    "GroupId": "core-service",
    "AutoOffsetReset": "Earliest"
  },
  "Postgres": {
    "ConnectionString": "Host=localhost;Port=5432;Database=pageapi;Username=postgres;Password=postgres"
  },
  "Gemini": {
    "ApiKey": "",
    "Model": "gemini-1.5-flash",
    "TimeoutSeconds": 5
  },
  "Processing": {
    "RateLimitPerMinute": 20,
    "RepeatedSpamThreshold": 3
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
